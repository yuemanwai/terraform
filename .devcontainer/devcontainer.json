{
  "name": "Terraform and AWS CLI Dev Container",
  "image": "mcr.microsoft.com/vscode/devcontainers/base:ubuntu",
  "features": {
    "terraform": "latest"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "hashicorp.terraform",
        "github.copilot",
        "mark-tucker.aws-cli-configure"
      ]
    }
  },
  "postStartCommand": "chmod +x setup.sh && ./setup.sh"
}
